{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "{{ ID }}",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "paymentDate": {
      "type": "string",
      "format": "date-time"
    },
    "amount": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "completed",
        "failed"
      ]
    },
    "location": {
      "type": "object",
      "$ref": "{{ JSM `util_location_wgs-84_1_0_0` }}"
    }
  },
  "required": [
    "id",
    "paymentDate",
    "amount",
    "currency",
    "status",
    "location"
  ]
}